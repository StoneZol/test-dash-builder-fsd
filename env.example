NEXT_PUBLIC_APP_ENV=development

# Client calls our Next.js proxy (no API key on the client)
NEXT_PUBLIC_APP_API_BASE_URL=/api

# Server-only: upstream REST Countries v5
REST_COUNTRIES_API_BASE_URL=https://api.restcountries.com/countries/v5
API_KEY=your_api_key_here

# Feature flags / env differences over shared top-100 dataset:
# development: Metric/News/Table options limited to 5, Chart regions to 3
# production: full dataset options for all widgets
NEXT_PUBLIC_ENABLE_DEBUG_PANEL=true
